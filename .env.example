# Library AI Chatbot — Environment Variables
# Copy this file to .env and fill in the values.

# Base URL of your Koha ILS REST API
KOHA_API_URL=http://localhost

# Path to the library information JSON file
LIBRARY_INFO_PATH=data/library_info.json

# Ollama / OpenRouter Configuration
# For local Ollama:
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:3b
# For OpenRouter (cloud LLM, works on Vercel):
# OLLAMA_URL=https://openrouter.ai/api/v1
# OLLAMA_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Admin Dashboard
# Shared API key for authenticating admin dashboard requests
ADMIN_API_KEY=your-admin-api-key-here

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Path to the SQLite database file for persistent session storage
SESSION_DB_PATH=data/sessions.db

# Turso Database (for persistent cloud storage on Vercel)
# Sign up at https://turso.tech and create a database
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# Email notifications for librarian handoff
# Option A: Google Workspace service account (recommended)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# SMTP_EMAIL is the Workspace user the service account delegates to:
# SMTP_EMAIL=chatbot@yourdomain.com
#
# Option B: Gmail SMTP with App Password (simpler, no Workspace needed)
# SMTP_EMAIL=your-library-email@gmail.com
# SMTP_PASSWORD=your-app-password
#
# Fallback notification email (used if no staff contacts are configured)
# LIBRARIAN_EMAIL=librarian@gmail.com
CHATBOT_PUBLIC_URL=http://localhost:8000

# Ably real-time messaging (for instant live chat delivery)
# Sign up at https://ably.com and create an app to get your API key
# ABLY_API_KEY=your-ably-api-key-here
